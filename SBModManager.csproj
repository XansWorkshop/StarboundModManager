<Project Sdk="Godot.NET.Sdk/4.7.0">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace></RootNamespace>
    <AssemblyTitle>SBModManager</AssemblyTitle>
    <AssemblyName>SBModManager</AssemblyName>
    <Nullable>enable</Nullable>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="EndianBinaryIO" Version="1.1.2" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="SimpleGIF">
      <HintPath>Includes\SimpleGIF.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>